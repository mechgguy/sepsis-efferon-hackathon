# Copy this file to .env and fill in your keys.
# Only one LLM provider key is required.
# OPENROUTER_API_KEY takes priority over OPENAI_API_KEY.

# --- OpenRouter (recommended) ---
OPENROUTER_API_KEY=your_openrouter_key_here

# --- OpenAI (alternative) ---
# OPENAI_API_KEY=""

# --- Optional: override the default model ---
# OpenRouter default: google/gemini-2.5-pro
# OpenAI default:     gpt-4o
# LLM_MODEL=google/gemini-2.5-pro

# --- Weaviate (defaults shown, change only if needed) ---
# WEAVIATE_HOST=localhost
# WEAVIATE_PORT=8090

# --- Embedding / Reranker models ---
# BGE_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
# RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3
# BATCH_SIZE=32
